# Copiá este archivo como  .env.local  y completá con tus valores reales.
# .env.local está en .gitignore: NUNCA se sube al repo.
#
# Estos valores están en Supabase -> Project Settings -> API
#
# El prefijo NEXT_PUBLIC_ hace que la variable viaje también al navegador.
# La "anon key" es pública por diseño: lo que protege los datos es RLS,
# no esconder esta clave.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aca
